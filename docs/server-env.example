# Copy this file to /www/wwwroot/shopclip-ai/.env on the server.
# Fill secrets on the server only. Do not commit real keys.

# API
NODE_ENV=production
PORT=4000
CORS_ORIGIN=http://152.136.252.134
JSON_BODY_LIMIT=10mb

# Web
VITE_API_URL=http://152.136.252.134/api

# Database
DATABASE_URL=postgresql://shopclip:123456@127.0.0.1:5432/shopclip_ai
PROJECT_STORE_MODE=prisma

# AI providers
AI_PROVIDER_MODE=mock
TTS_PROVIDER_MODE=mock
ARK_API_KEY=
AI_GENERAL_API_KEY=
AI_IMAGE_API_KEY=
AI_VIDEO_API_KEY=
AI_GENERAL_MODEL_ID=
AI_IMAGE_MODEL_ID=
AI_VIDEO_MODEL_ID=
ARK_IMAGE_SIZE=1024x1024
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VIDEO_GENERATION_PATH=/contents/generations/tasks
TTS_API_KEY=

# Merchant asset object storage
COS_PROVIDER_MODE=tencent
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=
COS_UPLOAD_PREFIX=projects

# Optional stock asset search
EXTERNAL_ASSET_PROVIDERS=
PEXELS_API_KEY=
PIXABAY_API_KEY=
FREESOUND_API_KEY=
