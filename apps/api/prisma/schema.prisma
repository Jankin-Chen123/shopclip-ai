generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  ready
  rendering
  completed
  failed
}

enum AssetType {
  image
  video
  reference
}

enum AssetStatus {
  uploaded
  processing
  ready
  failed
}

enum AssetSource {
  merchant_upload
  external_provider
  generated
  public_reference
}

enum AssetStorageProvider {
  local
  mock_cos
  tencent_cos
}

enum SceneStatus {
  draft
  generated
  edited
  regenerating
  failed
}

enum RenderTaskStatus {
  queued
  running
  completed
  failed
  retrying
}

enum TraceEventStatus {
  queued
  running
  completed
  failed
  retrying
}

enum ReferenceVideoStatus {
  registered
  analyzing
  ready
  failed
}

model Project {
  id                    String            @id @default(cuid())
  title                 String
  productName           String
  audience              String
  sellingPoints         String[]
  tone                  String
  style                 String
  targetDurationSeconds Int               @default(15)
  prepKeywords          String[]          @default([])
  status                ProjectStatus     @default(draft)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  assets                Asset[]
  assetProcessingJobs   AssetProcessingJob[]
  assetProcessingEvents AssetProcessingEvent[]
  referenceVideos       ReferenceVideo[]
  viralTemplates        ViralTemplate[]
  scripts               Script[]
  scenes                StoryboardScene[]
  renderTasks           RenderTask[]
  mockMetrics           MockMetric[]
}

model Asset {
  id              String                @id @default(cuid())
  projectId       String?
  type            AssetType
  status          AssetStatus           @default(uploaded)
  source          AssetSource           @default(merchant_upload)
  storageProvider AssetStorageProvider?
  objectKey       String?
  thumbnailKey    String?
  url             String
  name            String
  mimeType        String?
  sizeBytes       Int?
  tags            String[]
  embeddingText   String?
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  project         Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  slices          AssetSlice[]
  processingJobs  AssetProcessingJob[]
  processingEvents AssetProcessingEvent[]
  scenes          StoryboardScene[]
  referenceVideos ReferenceVideo[]

  @@index([projectId])
  @@index([objectKey])
}

model AssetProcessingJob {
  id        String      @id @default(cuid())
  projectId String?
  assetId   String
  status    AssetStatus
  steps     String[]
  message   String
  createdAt DateTime    @default(now())
  project   Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  asset     Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  events    AssetProcessingEvent[]

  @@index([projectId])
  @@index([assetId])
}

model AssetSlice {
  id          String   @id @default(cuid())
  assetId     String
  label       String
  startSecond Float?
  endSecond   Float?
  tags        String[]
  thumbnailKey String?
  embeddingText String?
  searchText  String?
  metadata    Json?
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model AssetProcessingEvent {
  id        String           @id @default(cuid())
  projectId String?
  jobId     String
  assetId   String
  step      String
  status    TraceEventStatus
  message   String
  progress  Int              @default(0)
  retryable Boolean          @default(false)
  createdAt DateTime         @default(now())
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  job       AssetProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  asset     Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([jobId])
  @@index([assetId])
}

model ReferenceVideo {
  id                String               @id @default(cuid())
  projectId         String?
  sourceAssetId     String?
  sourceUrl         String
  sourcePlatform    String
  sourceDeclaration String
  title             String
  author            String?
  category          String
  publicStats       Json?
  status            ReferenceVideoStatus @default(registered)
  analysis          Json?
  errorMessage      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  project           Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceAsset       Asset?               @relation(fields: [sourceAssetId], references: [id], onDelete: SetNull)
  segments          ReferenceVideoSegment[]

  @@index([projectId])
  @@index([sourceAssetId])
  @@index([sourcePlatform])
  @@index([category])
}

model ReferenceVideoSegment {
  id          String         @id @default(cuid())
  referenceId String
  role        String
  startSecond Float
  endSecond   Float
  summary     String
  copywriting String
  visualPrompt String
  metadata    Json?
  reference   ReferenceVideo @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@index([referenceId])
  @@index([role])
}

model ViralTemplate {
  id                 String   @id
  projectId          String?
  name               String
  category           String
  strategy           String
  factorSet          String[]
  narrativeStructure String[]
  shotRequirements   String[]
  copywritingRules   String[]
  riskRules          String[]
  sourceReferenceIds String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([category])
}

model Script {
  id          String            @id @default(cuid())
  projectId   String
  hook        String
  narrative   String
  constraints String[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenes      StoryboardScene[]

  @@index([projectId])
}

model StoryboardScene {
  id              String      @id @default(cuid())
  projectId       String
  scriptId        String?
  assetId         String?
  order           Int
  durationSeconds Float
  subtitle        String
  voiceover       String
  visualPrompt    String
  assetRecallQuery String?
  imageUrl        String?
  status          SceneStatus @default(draft)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  script          Script?     @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  asset           Asset?      @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([scriptId])
  @@index([assetId])
}

model RenderTask {
  id           String           @id @default(cuid())
  projectId    String
  status       RenderTaskStatus @default(queued)
  progress     Int              @default(0)
  previewUrl   String?
  exportUrl    String?
  errorMessage String?
  provider     String?
  providerTaskId String?
  sceneClips   Json?
  mediaSettings Json?
  videoSettings Json?
  retryOfRenderTaskId String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  traceEvents  TraceEvent[]

  @@index([projectId])
}

model TraceEvent {
  id           String           @id @default(cuid())
  renderTaskId String
  status       TraceEventStatus
  step         String
  message      String
  retryOfTraceEventId String?
  createdAt    DateTime         @default(now())
  renderTask   RenderTask       @relation(fields: [renderTaskId], references: [id], onDelete: Cascade)

  @@index([renderTaskId])
}

model MockMetric {
  id             String   @id @default(cuid())
  projectId      String
  sceneId        String?
  factor         String
  expectedImpact String
  value          Float
  evidence       String
  recommendation String
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
