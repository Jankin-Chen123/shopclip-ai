{
  "name": "@shopclip/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "smoke:ark-models": "tsx src/smoke/arkModelAccessSmoke.ts",
    "smoke:reference": "tsx src/smoke/realReferenceSmoke.ts",
    "start": "node dist/server.js",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@prisma/client": "^6.19.0",
    "@shopclip/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
