# API
PORT=4000
CORS_ORIGIN=http://localhost:5173
JSON_BODY_LIMIT=1mb

# Web
VITE_API_URL=http://localhost:4000/api

# Database, filled in during Part 002.
DATABASE_URL=postgresql://user:password@localhost:5432/shopclip_ai
# Use memory locally when no PostgreSQL is running. Production can omit this or set prisma.
PROJECT_STORE_MODE=memory

# AI provider secrets must be configured only on the server.
# Business runs default to real provider mode. Use mock only for explicit demo fixtures/tests.
AI_PROVIDER_MODE=ark
ARK_API_KEY=
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Optional per-role overrides. Leave blank to use ARK_API_KEY for that role.
AI_GENERAL_MODEL_ID=
AI_GENERAL_API_KEY=
# Keep this lower than the reverse proxy /api read timeout.
SCRIPT_TEXT_PROVIDER_TIMEOUT_MS=110000

# Viral reference breakdown. Explicit mock is allowed only for tests/demo fixtures.
REFERENCE_PROVIDER_MODE=ark
# Must be a text or multimodal understanding model/endpoint with Ark Responses API access.
# Do not use Seedance/video generation models here; those belong to AI_VIDEO_MODEL_ID.
AI_REFERENCE_MODEL_ID=
AI_REFERENCE_API_KEY=
REFERENCE_DOWNLOAD_PROVIDER_MODE=http
REFERENCE_DOWNLOAD_MAX_BYTES=52428800

# Multimodal asset understanding. Explicit mock is allowed only for tests/demo fixtures.
VISION_PROVIDER_MODE=ark
AI_VISION_MODEL_ID=
AI_VISION_API_KEY=
# Required when uploaded asset URLs are relative and the VLM must fetch them over the internet.
# Example: https://api.example.com
VISION_PUBLIC_BASE_URL=
# video_url sends the uploaded video URL to the model; frame_urls sends sampled frame URLs/data images; text_only sends metadata/OCR text only.
VISION_VIDEO_INPUT_MODE=video_url

# Use mock only for explicit demo fixtures/tests. Business render should use seedance/ark/real.
VIDEO_RENDER_PROVIDER_MODE=seedance
AI_VIDEO_MODEL_ID=
AI_VIDEO_API_KEY=
# Image input mode: first_frame sends one public product image with role=first_frame.
# Use none for text-only endpoints, or reference_image for models that support reference images.
AI_VIDEO_IMAGE_INPUT_MODE=first_frame
# Optional Seedance duration guard. The renderer sends each storyboard scene duration exactly.
# If a scene is outside this range, rendering fails with a clear validation error instead of silently changing duration.
AI_VIDEO_MIN_DURATION=4
AI_VIDEO_MAX_DURATION=12
# Seedance task submit/poll HTTP timeout. Keep this lower than the /api proxy timeout.
AI_VIDEO_PROVIDER_TIMEOUT_MS=120000

AI_IMAGE_MODEL_ID=
AI_IMAGE_API_KEY=
ARK_IMAGE_SIZE=1024x1024
# Seedream 5 image generation can take tens of seconds; keep this below the /api proxy timeout.
STORYBOARD_IMAGE_PROVIDER_TIMEOUT_MS=60000

# Seedance ratio/resolution/audio/watermark/seed are selected in the frontend render panel.
ARK_VIDEO_GENERATION_PATH=/contents/generations/tasks
# Optional: absolute path to server ffmpeg 6.1-static binary for composing scene clips.
FFMPEG_PATH=
RENDER_EXPORT_DIR=
TTS_PROVIDER_MODE=none
TTS_API_KEY=
# ASR is optional. Default none means video text is extracted from sampled frames by vision OCR.
ASR_PROVIDER_MODE=none
ASR_ENDPOINT_URL=
ASR_API_KEY=

# Optional stock asset search. API keys stay server-side.
# Use "pexels,pixabay,freesound" for server-configured real providers.
EXTERNAL_ASSET_PROVIDERS=
PEXELS_API_KEY=
PIXABAY_API_KEY=
FREESOUND_API_KEY=

# Merchant asset object storage. Use mock during local development, tencent on server.
COS_PROVIDER_MODE=mock
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=
# public returns COS_PUBLIC_BASE_URL/objectKey after export upload; signed returns a temporary COS signed GET URL.
COS_EXPORT_READ_MODE=public
COS_UPLOAD_PREFIX=projects
COS_INTELLIGENT_SEARCH_DATASET=
COS_INTELLIGENT_SEARCH_REGION=
COS_INTELLIGENT_SEARCH_ENABLED=
