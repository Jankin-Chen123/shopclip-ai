# API
PORT=4000
CORS_ORIGIN=http://localhost:5173
JSON_BODY_LIMIT=1mb

# Web
VITE_API_URL=http://localhost:4000/api

# Database, filled in during Part 002.
DATABASE_URL=postgresql://user:password@localhost:5432/shopclip_ai
# Use memory locally when no PostgreSQL is running. Production can omit this or set prisma.
PROJECT_STORE_MODE=memory

# AI provider secrets must be configured only on the server.
AI_PROVIDER_MODE=mock
ARK_API_KEY=
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Optional per-role overrides. Leave blank to use ARK_API_KEY for that role.
AI_GENERAL_MODEL_ID=
AI_GENERAL_API_KEY=

# Keep mock unless you explicitly want POST /render to submit real Seedance tasks.
VIDEO_RENDER_PROVIDER_MODE=mock
AI_VIDEO_MODEL_ID=
AI_VIDEO_API_KEY=
# Leave false for text-to-video endpoints. Set true only when the video endpoint supports reference/image-to-video.
AI_VIDEO_REFERENCE_IMAGES=false
# Optional Seedance duration controls. By default duration is derived from storyboard scenes and rounded up to 5/10/12.
AI_VIDEO_DURATION=
AI_VIDEO_ALLOWED_DURATIONS=5,10,12

AI_IMAGE_MODEL_ID=
AI_IMAGE_API_KEY=
ARK_IMAGE_SIZE=1024x1024

# Seedance ratio/resolution/audio/watermark/seed are selected in the frontend render panel.
ARK_VIDEO_GENERATION_PATH=/contents/generations/tasks
TTS_PROVIDER_MODE=mock
TTS_API_KEY=

# Optional stock asset search. API keys stay server-side.
# Use "pexels,pixabay,freesound" for server-configured real providers.
EXTERNAL_ASSET_PROVIDERS=
PEXELS_API_KEY=
PIXABAY_API_KEY=
FREESOUND_API_KEY=

# Merchant asset object storage. Use mock during local development, tencent on server.
COS_PROVIDER_MODE=mock
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=
COS_UPLOAD_PREFIX=projects
COS_INTELLIGENT_SEARCH_DATASET=
COS_INTELLIGENT_SEARCH_REGION=
COS_INTELLIGENT_SEARCH_ENABLED=
