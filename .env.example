# API
PORT=4000
CORS_ORIGIN=http://localhost:5173
JSON_BODY_LIMIT=1mb

# Web
VITE_API_URL=http://localhost:4000/api

# Database, filled in during Part 002.
DATABASE_URL=postgresql://user:password@localhost:5432/shopclip_ai
# Use memory locally when no PostgreSQL is running. Production can omit this or set prisma.
PROJECT_STORE_MODE=memory

# AI provider secrets must be configured only on the server.
AI_PROVIDER_MODE=mock
ARK_API_KEY=
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Optional per-role overrides. Leave blank to use ARK_API_KEY for that role.
AI_GENERAL_MODEL_ID=
AI_GENERAL_API_KEY=

# Multimodal asset understanding. Keep mock for stable local demos; set ark/real to call Ark.
VISION_PROVIDER_MODE=mock
AI_VISION_MODEL_ID=
AI_VISION_API_KEY=
# Required when uploaded asset URLs are relative and the VLM must fetch them over the internet.
# Example: https://api.example.com
VISION_PUBLIC_BASE_URL=
# video_url sends the uploaded video URL to the model; frame_urls sends only public sampled frame URLs; text_only sends metadata/transcript only.
VISION_VIDEO_INPUT_MODE=video_url

# Keep mock unless you explicitly want POST /render to submit real Seedance tasks.
VIDEO_RENDER_PROVIDER_MODE=mock
AI_VIDEO_MODEL_ID=
AI_VIDEO_API_KEY=
# Image input mode: first_frame sends one public product image with role=first_frame.
# Use none for text-only endpoints, or reference_image for models that support reference images.
AI_VIDEO_IMAGE_INPUT_MODE=first_frame
# Optional Seedance duration controls. By default each scene duration is rounded up to 5/10.
AI_VIDEO_DURATION=
AI_VIDEO_ALLOWED_DURATIONS=5,10

AI_IMAGE_MODEL_ID=
AI_IMAGE_API_KEY=
ARK_IMAGE_SIZE=1024x1024

# Seedance ratio/resolution/audio/watermark/seed are selected in the frontend render panel.
ARK_VIDEO_GENERATION_PATH=/contents/generations/tasks
# Optional: absolute path to server ffmpeg 6.1-static binary for composing scene clips.
FFMPEG_PATH=
RENDER_EXPORT_DIR=
TTS_PROVIDER_MODE=mock
TTS_API_KEY=

# Optional stock asset search. API keys stay server-side.
# Use "pexels,pixabay,freesound" for server-configured real providers.
EXTERNAL_ASSET_PROVIDERS=
PEXELS_API_KEY=
PIXABAY_API_KEY=
FREESOUND_API_KEY=

# Merchant asset object storage. Use mock during local development, tencent on server.
COS_PROVIDER_MODE=mock
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=
# public returns COS_PUBLIC_BASE_URL/objectKey after export upload; signed returns a temporary COS signed GET URL.
COS_EXPORT_READ_MODE=public
COS_UPLOAD_PREFIX=projects
COS_INTELLIGENT_SEARCH_DATASET=
COS_INTELLIGENT_SEARCH_REGION=
COS_INTELLIGENT_SEARCH_ENABLED=
